# .editorconfig - DRSJuryManager

root = true

[*]
charset = utf-8-bom
end_of_line = lf
indent_style = space
trim_trailing_whitespace = true
dotnet_diagnostic.BCB001.severity = error
dotnet_diagnostic.BCB002.severity = error
dotnet_diagnostic.BCB003.severity = error
dotnet_diagnostic.BCB004.severity = error
dotnet_diagnostic.BCB005.severity = warning
dotnet_diagnostic.BCB006.severity = warning
dotnet_diagnostic.BCB007.severity = warning

[*.{cs,razor}]
indent_size = 4
file_header_template = Copyright (c) Bell County, Texas. All rights reserved.

[*.json]
indent_size = 2

[*.{csproj,vbproj,vcxproj,vcxproj.filters,proj,projitems,shproj,props,targets,ruleset,config,nuspec,resx,vsixmanifest,vsct}]
indent_size = 2

[*.{sh,ps1,scss}]
indent_size = 2

[*.{js,mjs,ts}]
indent_size = 4

[*.cs]
csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true
csharp_new_line_before_members_in_object_initializers = true
csharp_new_line_before_members_in_anonymous_types = true
csharp_new_line_between_query_expression_clauses = true

csharp_indent_block_contents = true
csharp_indent_braces = false
csharp_indent_case_contents = true
csharp_indent_case_contents_when_block = true
csharp_indent_labels = flush_left
csharp_indent_switch_labels = true

csharp_preferred_modifier_order = public,private,protected,internal,file,static,extern,new,virtual,abstract,sealed,override,readonly,unsafe,required,volatile,async:suggestion
csharp_style_var_for_built_in_types = true:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = true:suggestion

dotnet_style_qualification_for_field = false:suggestion
dotnet_style_qualification_for_property = false:suggestion
dotnet_style_qualification_for_method = false:suggestion
dotnet_style_qualification_for_event = false:suggestion
dotnet_style_predefined_type_for_locals_parameters_members = true:suggestion
dotnet_style_predefined_type_for_member_access = true:suggestion

dotnet_diagnostic.BL0005.severity = error
dotnet_diagnostic.CS1591.severity = warning
dotnet_diagnostic.CS4014.severity = error
dotnet_diagnostic.IDE0055.severity = suggestion
dotnet_diagnostic.IDE0073.severity = warning

csharp_style_prefer_primary_constructors = true:none
csharp_remove_unnecessary_imports = true:warning
dotnet_code_style_unused_parameters = all:warning
dotnet_style_prefer_compound_assignment = true:suggestion
dotnet_style_prefer_simplified_conditional_expression = true:suggestion
dotnet_style_remove_unnecessary_cast = true:error
